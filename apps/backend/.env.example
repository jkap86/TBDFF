# TBDFF Backend

# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tbdff_dev

# Auth
JWT_SECRET=change-me-to-a-random-string-that-is-at-least-64-characters-long-for-security

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:8081,http://localhost:3000
